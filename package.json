{
  "name": "@forgelore/opencode",
  "version": "0.1.0",
  "description": "OpenCode plugin for forgelore — multi-agent spec-driven development",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "forgelore-opencode": "./dist/setup.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "files": ["dist", "agents", "skills"],
  "license": "MIT",
  "peerDependencies": {
    "@forgelore/core": ">=0.2.0"
  },
  "peerDependenciesMeta": {
    "@forgelore/core": {
      "optional": true
    }
  },
  "devDependencies": {
    "@forgelore/core": "^0.2.3",
    "@opencode-ai/plugin": "^1.2.24",
    "@types/node": "^22.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/DxVapor/opencode-forgelore.git"
  },
  "keywords": [
    "opencode",
    "opencode-plugin",
    "plugin",
    "forgelore",
    "spec-driven",
    "multi-agent",
    "ai-development"
  ]
}
